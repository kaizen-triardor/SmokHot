// Smokin' Hot CMS Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  directUrl = env("DIRECT_URL")
  url      = env("DATABASE_URL")
}

// Product Management
model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  blurb       String   // Short marketing description
  heatLevel   String   // 'mild', 'hot', 'extra-hot', 'smokin-hot'
  heatNumber  Int      // 1-4 scale
  price       Int      // In RSD (as cents for precision)
  originalPrice Int?   // For sale pricing
  
  // Images (stored as JSON paths)
  mainImage     String?
  galleryImages String? // JSON array of paths
  thumbnail     String?
  
  // Product Details
  ingredients   String? // JSON array
  volume        String  @default("150ml")
  scoville      Int?
  pairings      String? // JSON array of food recommendations
  
  // Inventory
  inStock     Boolean @default(true)
  stockCount  Int     @default(0)
  featured    Boolean @default(false)
  
  // Categories
  categories  String? // JSON array
  
  // Nutrition (optional)
  calories    Int?
  fat         Float?
  carbs       Float?
  protein     Float?
  sodium      Int?
  
  // SEO
  seoTitle       String?
  seoDescription String?
  seoOgImage     String?

  // Soft delete — keeps historical orders readable
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

// Content Management
model Content {
  id        String   @id @default(cuid())
  key       String   @unique // e.g., 'hero_title', 'about_text', 'contact_info'
  title     String   // Human-readable name
  content   String   // The actual content (text/HTML/JSON)
  type      String   // 'text', 'html', 'json', 'image'
  section   String   // 'hero', 'about', 'contact', 'global'
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("content")
}

// Order Management (COD focused)
model Order {
  id          String   @id @default(cuid())
  orderNumber String   @unique // Human-readable order ID
  
  // Customer Info
  customerName    String
  customerPhone   String
  customerAddress String
  notes           String?
  
  // Order Details
  items       String  // JSON array of ordered items
  totalAmount Int     // Total in RSD (as cents)
  
  // Status Management
  status      String  @default("pending") // 'pending', 'confirmed', 'shipped', 'delivered', 'cancelled'
  
  // Delivery Info
  shippingCost    Int @default(0)
  estimatedDelivery DateTime?
  trackingNumber  String?
  
  // Internal Notes
  adminNotes  String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

// Admin User Management
model Admin {
  id       String @id @default(cuid())
  email    String @unique
  name     String
  password String // Hashed with bcrypt
  role     String @default("admin") // 'admin', 'super_admin'
  active   Boolean @default(true)

  lastLoginAt DateTime?
  passwordChangedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

// Blog Posts
model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   // HTML (sanitized at write time via DOMPurify)
  excerpt     String   // Short preview text
  coverImage  String?  // Image URL/path
  published   Boolean  @default(false)
  author      String   @default("SmokHot")
  tags        String?  // JSON array of tags

  // SEO
  seoTitle       String?
  seoDescription String?
  seoOgImage     String?

  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blog_posts")
}

// Gallery Images
model GalleryImage {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  category    String   @default("general") // 'events', 'products', 'customers', 'food'
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("gallery_images")
}

// Tour Events (Turneja)
model TourEvent {
  id          String   @id @default(cuid())
  title       String
  location    String
  date        DateTime
  time        String   // e.g., "09:00 - 15:00"
  status      String   @default("upcoming") // 'upcoming', 'past', 'cancelled'
  highlight   String?  // Summary of past event
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tour_events")
}

// Settings Management
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String // JSON for complex settings

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// Audit Log — records admin actions for accountability
model AuditLog {
  id          String   @id @default(cuid())
  adminId     String   // FK-like reference to admin
  adminEmail  String   // denormalized so log remains readable after admin delete
  action      String   // 'CREATE', 'UPDATE', 'DELETE', 'LOGIN', 'LOGOUT', 'PASSWORD_CHANGE'
  resource    String   // 'product', 'order', 'blog', 'gallery', 'turneja', 'settings', 'admin'
  resourceId  String?  // the affected row id (when applicable)
  summary     String?  // short human-readable description
  metadata    String?  // JSON blob with before/after or extra fields
  ip          String?
  userAgent   String?

  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([adminId])
  @@index([resource])
  @@map("audit_logs")
}