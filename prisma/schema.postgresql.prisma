// Smokin' Hot CMS Database Schema — PostgreSQL (Supabase)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Supabase requires this for migrations
}

// Product Management
model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  blurb       String
  heatLevel   String
  heatNumber  Int
  price       Int
  originalPrice Int?

  mainImage     String?
  galleryImages String?
  thumbnail     String?

  ingredients   String?
  volume        String  @default("150ml")
  scoville      Int?
  pairings      String?

  inStock     Boolean @default(true)
  stockCount  Int     @default(0)
  featured    Boolean @default(false)

  categories  String?

  calories    Int?
  fat         Float?
  carbs       Float?
  protein     Float?
  sodium      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

// Content Management
model Content {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  content   String
  type      String
  section   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("content")
}

// Order Management (COD focused)
model Order {
  id          String   @id @default(cuid())
  orderNumber String   @unique

  customerName    String
  customerPhone   String
  customerAddress String
  notes           String?

  items       String
  totalAmount Int

  status      String  @default("pending")

  shippingCost    Int @default(0)
  estimatedDelivery DateTime?
  trackingNumber  String?

  adminNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

// Admin User Management
model Admin {
  id       String @id @default(cuid())
  email    String @unique
  name     String
  password String
  role     String @default("admin")
  active   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

// Blog Posts
model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String
  coverImage  String?
  published   Boolean  @default(false)
  author      String   @default("SmokHot")
  tags        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blog_posts")
}

// Gallery Images
model GalleryImage {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  category    String   @default("general")
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("gallery_images")
}

// Settings Management
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}
